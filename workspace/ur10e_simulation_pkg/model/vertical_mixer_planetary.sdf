      <child>planet_1_link</child>
      <pose>0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>4.0</damping>
          <friction>1.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="planet_2_carrier">
      <pose>0 0 0 0 0 0</pose>
      <velocity_decay>
        <linear>0.2</linear>
        <angular>0.8</angular>
      </velocity_decay>
      <inertial>
        <mass>5.0</mass>
        <inertia>
          <ixx>0.0022</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.0022</iyy> <iyz>0.0</iyz> <izz>0.0023</izz>
        </inertia>
      </inertial>
    </link>

    <joint name="planet_2_orbit_joint" type="revolute">
      <parent>base_link</parent>
      <child>planet_2_carrier</child>
      <pose>0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>4.0</damping>
          <friction>1.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="planet_2_link">
      <pose>-0.155847 0.456481 0 0 0 0</pose>
      <velocity_decay>
        <linear>0.2</linear>
        <angular>0.8</angular>
      </velocity_decay>
      <inertial>
        <pose>0 0 0.10 0 0 0</pose>
        <mass>12.0</mass>
        <inertia>
          <ixx>0.069</ixx> <ixy>0.0</ixy> <ixz>0.0</ixz>
          <iyy>0.069</iyy> <iyz>0.0</iyz> <izz>0.012</izz>
        </inertia>
