<?xml version="1.0"?>
<robot name="vertical_planetary_mixer" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===== Materials ===== -->
  <material name="grey">      <color rgba="0.7 0.7 0.7 1.0"/> </material>
  <material name="dark_grey"> <color rgba="0.3 0.3 0.3 1.0"/> </material>
  <material name="blue">      <color rgba="0.2 0.4 0.8 1.0"/> </material>
  <material name="red">       <color rgba="0.8 0.2 0.2 1.0"/> </material>
  <material name="green">     <color rgba="0.2 0.8 0.2 1.0"/> </material>

  <!-- ===== World (fixed root) ===== -->
  <link name="world"/>

  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ===== Base / Frame Structure ===== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="50.0"/>
      <inertia ixx="5.0" ixy="0.0" ixz="0.0"
               iyy="5.0" iyz="0.0" izz="4.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ur10e_simulation_pkg/meshes/structure.stl" scale="1 1 1"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ur10e_simulation_pkg/meshes/structure.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== Shroud (outer rotating bowl/cover) ===== -->
  <link name="shroud_link">
    <inertial>
      <!-- CoM in local frame, centred vertically on the shroud geometry -->
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="3.0"/>
      <inertia ixx="0.0975" ixy="0.0" ixz="0.0"
               iyy="0.0975" iyz="0.0" izz="0.054"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ur10e_simulation_pkg/meshes/shroud.stl" scale="1 1 1"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ur10e_simulation_pkg/meshes/shroud.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="shroud_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="shroud_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ===== Sun Gear / Central Blade ===== -->
  <link name="sun_link">
    <inertial>
      <!-- CoM in local frame, centred vertically on the sun geometry -->
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.012" ixy="0.0" ixz="0.0"
               iyy="0.012" iyz="0.0" izz="0.008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ur10e_simulation_pkg/meshes/middle_blade.stl" scale="1 1 1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ur10e_simulation_pkg/meshes/middle_blade.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="sun_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="sun_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <!-- ===== Planet 1 — Carrier (massless orbit pivot) ===== -->
  <link name="planet_1_carrier">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0.0" ixz="0.0"
               iyy="1e-6" iyz="0.0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="planet_1_orbit_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="planet_1_carrier"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.02"/>
  </joint>

  <!-- Planet 1 blade link.
       The spin joint places the blade at the orbital radius
       (origin xyz="0.155943 -0.456764 0"), so all inertial and
       collision geometry is expressed in that local frame → CoM at (0 0 0.10). -->
  <link name="planet_1_link">
    <inertial>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.010" ixy="0.0" ixz="0.0"
               iyy="0.010" iyz="0.0" izz="0.004"/>
    </inertial>
    <visual>
      <!-- Visual origin compensates so the mesh sits at the correct
           world position after the joint offset is applied. -->
      <origin xyz="-0.155943 0.456764 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ur10e_simulation_pkg/meshes/blade_1.stl" scale="1 1 1"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="-0.155943 0.456764 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ur10e_simulation_pkg/meshes/blade_1.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="planet_1_spin_joint" type="continuous">
    <parent link="planet_1_carrier"/>
    <child  link="planet_1_link"/>
    <origin xyz="0.155943 -0.456764 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.02"/>
  </joint>

  <!-- ===== Planet 2 — Carrier (massless orbit pivot) ===== -->
  <link name="planet_2_carrier">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0.0" ixz="0.0"
               iyy="1e-6" iyz="0.0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="planet_2_orbit_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="planet_2_carrier"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.02"/>
  </joint>

  <!-- Planet 2 blade link — same fix as planet 1. -->
  <link name="planet_2_link">
    <inertial>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.010" ixy="0.0" ixz="0.0"
               iyy="0.010" iyz="0.0" izz="0.004"/>
    </inertial>
    <visual>
      <origin xyz="0.155847 -0.456481 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ur10e_simulation_pkg/meshes/blade_2.stl" scale="1 1 1"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0.155847 -0.456481 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ur10e_simulation_pkg/meshes/blade_2.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="planet_2_spin_joint" type="continuous">
    <parent link="planet_2_carrier"/>
    <child  link="planet_2_link"/>
    <origin xyz="-0.155847 0.456481 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.02"/>
  </joint>

  <!-- ===== ros2_control — position interfaces for all continuous joints ===== -->
  <ros2_control name="mixer_planetary_system" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="sun_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="shroud_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="planet_1_orbit_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="planet_1_spin_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="planet_2_orbit_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="planet_2_spin_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ===== Gazebo plugin — path resolved at launch time via find_package ===== -->
  <gazebo>
    <plugin name="gazebo_ros2_control"
            filename="libgazebo_ros2_control.so">
      <!-- Use $(find ur10e_simulation_pkg) in a xacro file, or resolve
           the path in your Python launch file and pass it in as an arg. -->
      <parameters>/home/nithish/ur10e_force_mode_ws/src/ur10e_simulation_pkg/config/controllers.yaml</parameters>
      <ros>
        <namespace>/mixer</namespace>
      </ros>
    </plugin>
  </gazebo>

</robot>